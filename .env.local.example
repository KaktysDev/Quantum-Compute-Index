# ──────────────────────────────────────────────────────────────────────────────
# QuantumForge Exchange — environment variables
# Copy this file to ".env.local" for local dev, and add the same vars in Vercel.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase ─ Project Settings → API
# These two are safe to expose to the browser (anon key is public by design).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Supabase service-role key — SERVER ONLY, NEVER expose to the browser.
# Used by the cron job and key-decryption logic. (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# 32+ char secret used to encrypt provider API keys at rest (AES-256-GCM).
# Generate with:  openssl rand -base64 32
KEY_ENCRYPTION_SECRET="generate-a-long-random-string-min-32-chars"

# Shared secret the daily cron uses to authenticate to /api/cron/refresh.
# Generate with:  openssl rand -base64 32
CRON_SECRET="generate-another-long-random-string"

# Public site URL — used to build OAuth redirect URLs.
# Local: http://localhost:3000   |   Prod: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# GitHub App repository connection. Set the App callback URL to:
# https://your-domain.com/api/integrations/github/callback
GITHUB_APP_ID="123456"
GITHUB_APP_SLUG="your-qrouter-app"
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
GITHUB_STATE_SECRET="generate-a-long-random-string"

# Optional local/public-repository fallback when a GitHub App is unavailable.
GITHUB_TOKEN="github_pat_..."

# QRouter billing
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Physical execution. AWS also requires standard AWS_ACCESS_KEY_ID and
# AWS_SECRET_ACCESS_KEY environment variables.
BRAKET_OUTPUT_BUCKET="your-amazon-braket-results-bucket"
IBM_QUANTUM_TOKEN="your-ibm-quantum-token"
IBM_QUANTUM_INSTANCE="ibm-q/open/main"
IBM_QUANTUM_BACKEND="ibm_brisbane"

# Optional Vultr-hosted Qiskit Aer/cuQuantum worker. Without this, development
# uses the bundled state-vector engine.
VULTR_SIMULATOR_URL="https://simulator.example.com"
VULTR_SIMULATOR_TOKEN="generate-a-long-worker-token"

# Hardware-aware Qiskit compiler. This may point at the same worker as the
# Vultr simulator. Physical QPU execution is rejected when it is missing.
QROUTER_COMPILER_URL="https://compiler.example.com"
QROUTER_COMPILER_TOKEN="generate-a-long-compiler-token"

# Direct IonQ execution. When absent, IonQ routes through Amazon Braket.
IONQ_API_KEY="your-ionq-cloud-api-key"
IONQ_BACKEND="qpu.aria-1"
IONQ_DEBIASING="false"

# Approved partner execution bridges. Gate-model OpenQASM is intentionally not
# routed to photonic backends unless a native bridge is configured.
QUANDELA_EXECUTION_URL="https://quandela-bridge.example.com"
QUANDELA_API_KEY="your-quandela-bridge-key"
XANADU_EXECUTION_URL="https://xanadu-bridge.example.com"
XANADU_API_KEY="your-xanadu-bridge-key"
QI_EXECUTION_URL="https://quantum-inspire-bridge.example.com"
QI_API_KEY="your-quantum-inspire-bridge-key"
