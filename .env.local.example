# ──────────────────────────────────────────────────────────────────────────────
# QuantumForge Exchange — environment variables
# Copy this file to ".env.local" for local dev, and add the same vars in Vercel.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase ─ Project Settings → API
# These two are safe to expose to the browser (anon key is public by design).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Supabase service-role key — SERVER ONLY, NEVER expose to the browser.
# Used by the cron job and key-decryption logic. (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# 32+ char secret used to encrypt provider API keys at rest (AES-256-GCM).
# Generate with:  openssl rand -base64 32
KEY_ENCRYPTION_SECRET="generate-a-long-random-string-min-32-chars"

# Shared secret the daily cron uses to authenticate to /api/cron/refresh.
# Generate with:  openssl rand -base64 32
CRON_SECRET="generate-another-long-random-string"

# Public site URL — used to build OAuth redirect URLs.
# Local: http://localhost:3000   |   Prod: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
