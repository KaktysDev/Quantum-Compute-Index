QROUTER_WORKER_IMAGE=registry.example.com/qrouter-simulator:latest
WORKER_DOMAIN=simulator.example.com
ACME_EMAIL=ops@example.com

SIMULATOR_TOKEN=replace-with-at-least-32-random-bytes
REQUIRE_GPU=true
WORKERS=2
MAX_QUEUED_JOBS=100
MAX_QUBITS=30
MAX_SHOTS=1000000

# Optional: enable live IBM target compilation and IBM Runtime submission.
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_INSTANCE=ibm-q/open/main
IBM_QUANTUM_BACKEND=ibm_brisbane
