:root{--qr-bg:#0b0b0c;--qr-panel:#121214;--qr-raised:#171719;--qr-line:rgba(255,255,255,.09);--qr-muted:#8e8e95;--qr-orange:#ff6b00;--qr-orange-hover:#ff8533;--qr-green:#4ade80;--qr-blue:#38bdf8}
.qr-landing,.console-shell,.onboarding-page{background:var(--qr-bg);color:#f7f7f8;letter-spacing:0}.qr-hero{position:relative;min-height:min(880px,96svh);overflow:hidden;border-bottom:1px solid var(--qr-line)}.qr-hero-image{object-fit:cover;object-position:center}.qr-hero-shade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(5,5,6,.98),rgba(5,5,6,.74) 35%,rgba(5,5,6,.08) 75%),linear-gradient(0deg,rgba(5,5,6,.9),transparent 35%)}
.qr-public-nav{position:relative;z-index:3;height:72px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 clamp(1.25rem,4vw,4.5rem);border-bottom:1px solid rgba(255,255,255,.12);background:rgba(9,9,10,.5);backdrop-filter:blur(14px)}.qr-public-nav nav{display:flex;gap:2rem;font-size:.82rem;color:#aaa}.qr-public-nav nav a:hover{color:#fff}.qr-nav-console{justify-self:end;display:inline-flex;align-items:center;gap:.5rem;font-size:.82rem;font-weight:600}.qr-hero-copy{position:relative;z-index:2;width:min(660px,calc(100% - 2.5rem));margin:clamp(5rem,12vh,9rem) 0 0 clamp(1.25rem,8vw,9rem)}.qr-live{display:flex;align-items:center;gap:.6rem;margin:0 0 1.5rem;color:#b9b9bc;font:600 .68rem/1 var(--font-mono);text-transform:uppercase}.qr-live span{width:7px;height:7px;border-radius:50%;background:var(--qr-green);box-shadow:0 0 12px rgba(74,222,128,.7)}.qr-hero h1{margin:0;font-size:clamp(5rem,11vw,10rem);line-height:.78;font-weight:700;letter-spacing:0}.qr-hero-lede{margin:2.1rem 0 0;max-width:620px;font-size:clamp(1.55rem,2.4vw,2.35rem);line-height:1.15;font-weight:500}.qr-hero-body{max-width:540px;margin:1.2rem 0 2rem;color:#a8a8ad;font-size:1rem;line-height:1.65}.qr-launch{position:relative;display:inline-flex;align-items:center;gap:.65rem;min-height:48px;padding:0 1.25rem;border:1px solid #ff7b1c;border-radius:6px;background:var(--qr-orange);color:#0b0b0c;font-weight:750;cursor:pointer;transition:background 160ms,transform 160ms,box-shadow 160ms}.qr-launch:hover{background:var(--qr-orange-hover);transform:translateY(-1px);box-shadow:0 10px 36px rgba(255,107,0,.22)}.qr-launch-pulse{position:absolute;inset:-1px;border:1px solid #ff8533;border-radius:6px;animation:qr-pulse 2.6s infinite}@keyframes qr-pulse{70%,100%{transform:scale(1.14,1.5);opacity:0}}.qr-proof{display:flex;flex-wrap:wrap;gap:1.25rem;margin-top:1.6rem;color:#8e8e93;font-size:.72rem}.qr-proof span{display:flex;gap:.4rem;align-items:center}.qr-proof svg{color:var(--qr-green)}
.qr-network-strip{position:absolute;z-index:2;left:0;right:0;bottom:0;display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid rgba(255,255,255,.12);background:rgba(8,8,9,.78);backdrop-filter:blur(14px);padding-left:clamp(1.25rem,8vw,9rem)}.qr-network-strip>div{display:grid;grid-template-columns:1fr auto;align-items:baseline;gap:.25rem 1rem;min-height:90px;padding:1.25rem 2rem;border-left:1px solid rgba(255,255,255,.1)}.qr-network-strip span{grid-column:1/-1;color:#77777d;font:600 .64rem var(--font-mono);text-transform:uppercase}.qr-network-strip strong{font:600 1.35rem var(--font-mono)}.qr-network-strip em{color:#999;font:normal .72rem var(--font-mono)}.qr-network-strip .positive{color:var(--qr-green)}.qr-network-strip .negative{color:#fb7185}.qr-band{padding:clamp(5rem,10vw,9rem) clamp(1.25rem,8vw,9rem);border-bottom:1px solid var(--qr-line)}.qr-section-intro{margin-bottom:3.5rem}.qr-section-intro.split{display:flex;justify-content:space-between;align-items:end;gap:4rem}.qr-section-intro.split>p{max-width:420px;color:var(--qr-muted);line-height:1.65}.qr-eyebrow{margin:0 0 .9rem;color:var(--qr-orange-hover);font:650 .68rem var(--font-mono);text-transform:uppercase}.qr-section-intro h2,.qr-developer h2,.qr-final h2{margin:0;font-size:clamp(2.5rem,5vw,5.2rem);line-height:.98;letter-spacing:0;font-weight:570}.qr-workflow{background:#0e0e10}.qr-flow-line{display:grid;grid-template-columns:repeat(4,1fr);border-block:1px solid var(--qr-line)}.qr-flow-line article{min-height:220px;padding:1.7rem;border-right:1px solid var(--qr-line)}.qr-flow-line article:last-child{border:0}.qr-flow-line article>div{display:flex;justify-content:space-between;color:#ff7b1c}.qr-flow-line article>div span{color:#55555a;font:.72rem var(--font-mono)}.qr-flow-line h3{margin:4rem 0 .7rem;font-size:1.25rem}.qr-flow-line p{margin:0;max-width:220px;color:#88888e;font-size:.85rem;line-height:1.6}.qr-network{background:#0b0b0c}.qr-backend-table{border-top:1px solid var(--qr-line)}.qr-table-head,.qr-table-row{display:grid;grid-template-columns:2fr 1.4fr .6fr .6fr .7fr .8fr;align-items:center;gap:1rem;min-height:58px;padding:0 1rem;border-bottom:1px solid var(--qr-line)}.qr-table-head{min-height:42px;color:#66666c;font:600 .62rem var(--font-mono);text-transform:uppercase}.qr-table-row{font:.78rem var(--font-mono)}.qr-table-row:hover{background:rgba(255,255,255,.025)}.qr-table-row>span:first-child{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:0 .65rem}.qr-table-row small{grid-column:2;color:#69696f;font-size:.62rem}.provider-dot{grid-row:1/3;width:7px;height:7px;border-radius:50%;background:var(--qr-blue)}.provider-dot.qpu{background:var(--qr-orange)}.qr-table-row .online{color:var(--qr-green)}.qr-table-row .standby{color:#facc15}
.qr-developer{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(320px,.75fr);gap:clamp(3rem,8vw,9rem);align-items:center;background:#101012}.qr-code-window{overflow:hidden;border:1px solid rgba(255,255,255,.12);border-radius:7px;background:#09090a;box-shadow:0 30px 80px rgba(0,0,0,.35)}.qr-code-bar{display:flex;align-items:center;gap:.45rem;height:42px;padding:0 1rem;border-bottom:1px solid var(--qr-line);background:#141416}.qr-code-bar span{width:7px;height:7px;border-radius:50%;background:#404045}.qr-code-bar span:first-child{background:var(--qr-orange)}.qr-code-bar em{margin-left:.5rem;color:#707077;font:normal .68rem var(--font-mono)}.qr-code-window pre{margin:0;padding:2rem;overflow-x:auto;color:#d9d9dd;font:.85rem/1.9 var(--font-mono)}.qr-developer-copy>p:not(.qr-eyebrow){color:#929298;line-height:1.7}.qr-developer-copy ul{list-style:none;padding:0;margin:1.8rem 0}.qr-developer-copy li{display:flex;align-items:center;gap:.7rem;margin:.85rem 0;font-size:.85rem}.qr-developer-copy li svg{color:var(--qr-orange)}.qr-text-cta{display:inline-flex;align-items:center;gap:.6rem;color:var(--qr-orange-hover);font-weight:650;font-size:.86rem}.qr-final{padding:clamp(6rem,12vw,12rem) 1.25rem;text-align:center}.qr-final h2{margin-bottom:2.5rem;font-size:clamp(3.5rem,9vw,8rem)}.qr-footer{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:2rem clamp(1.25rem,4vw,4.5rem);border-top:1px solid var(--qr-line);color:#696970;font-size:.72rem}
.qr-modal-backdrop{position:fixed;z-index:100;inset:0;display:grid;place-items:center;padding:1rem;background:rgba(0,0,0,.8);backdrop-filter:blur(12px)}.qr-modal{position:relative;width:min(440px,100%);padding:2.2rem;border:1px solid rgba(255,255,255,.14);border-radius:8px;background:#121214;box-shadow:0 30px 100px #000}.qr-modal .close{position:absolute;right:1rem;top:1rem}.qr-modal-mark{display:grid;place-items:center;width:48px;height:48px;margin-bottom:1.5rem;border:1px solid rgba(255,107,0,.4);border-radius:6px;background:rgba(255,107,0,.08);color:#ff7b1c}.qr-modal h2{margin:0;font-size:1.7rem;line-height:1.15}.qr-modal>p:not(.qr-eyebrow){color:#929298;line-height:1.6}.qr-modal small{display:block;margin-top:1rem;color:#65656b;font-size:.65rem;line-height:1.5}.qr-google,.qr-google>button{width:100%;margin-top:1rem}.qr-icon-button{display:inline-grid;width:34px;height:34px;place-items:center;border:1px solid var(--qr-line);border-radius:5px;background:#171719;color:#aaa;cursor:pointer}.qr-icon-button:hover{color:#fff;border-color:#444}
/* Console */
.console-shell{min-height:100vh;background-image:linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:52px 52px}.console-topbar{height:62px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 clamp(1rem,3vw,2.5rem);border-bottom:1px solid var(--qr-line);background:rgba(11,11,12,.94);backdrop-filter:blur(14px)}.console-workspace{display:flex;align-items:center;gap:.65rem;padding:.45rem .7rem;border:1px solid var(--qr-line);border-radius:5px;font-size:.75rem}.console-account{justify-self:end;display:flex;align-items:center;gap:1rem;color:#777;font-size:.7rem}.console-account button{border:0;background:none;color:#aaa;cursor:pointer}.console-balance{padding:.35rem .55rem;border:1px solid rgba(74,222,128,.2);border-radius:4px;background:rgba(74,222,128,.06);color:var(--qr-green);font-family:var(--font-mono)}.console-tabs{position:sticky;z-index:20;top:0;display:flex;justify-content:center;gap:.2rem;min-height:48px;padding:.4rem 1rem;border-bottom:1px solid var(--qr-line);background:rgba(18,18,20,.92);backdrop-filter:blur(14px)}.console-tabs a{display:flex;align-items:center;gap:.45rem;min-height:34px;padding:0 .8rem;border-radius:5px;color:#85858b;font-size:.72rem;font-weight:600}.console-tabs a:hover{color:#fff;background:rgba(255,255,255,.04)}.console-tabs a.active{background:rgba(255,107,0,.1);color:#ff9147}.console-main{width:min(1320px,100%);margin:auto;padding:clamp(2rem,4vw,3.5rem) clamp(1rem,3vw,2.5rem) 5rem}.console-page{display:flex;flex-direction:column;gap:1.5rem}.console-page-heading{display:flex;justify-content:space-between;align-items:end;gap:2rem;margin-bottom:1.2rem}.console-page-heading.compact{margin-bottom:.25rem}.console-page-heading h1{margin:0;font-size:clamp(2rem,4vw,3.5rem);line-height:1;font-weight:620;letter-spacing:0}.console-page-heading p:not(.qr-eyebrow){margin:.75rem 0 0;color:var(--qr-muted);font-size:.85rem}.console-primary,.console-secondary,.console-danger{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;min-height:38px;padding:0 .9rem;border-radius:5px;font-size:.75rem;font-weight:700;cursor:pointer}.console-primary{border:1px solid #ff7b1c;background:var(--qr-orange);color:#090909}.console-primary:hover{background:var(--qr-orange-hover)}.console-secondary{border:1px solid var(--qr-line);background:#1a1a1d;color:#ddd}.console-danger{border:1px solid rgba(251,113,133,.25);background:rgba(251,113,133,.06);color:#fb7185}.full{width:100%}.console-primary:disabled{opacity:.5;cursor:not-allowed}.console-panel{border:1px solid var(--qr-line);border-radius:7px;background:rgba(18,18,20,.96);box-shadow:0 18px 50px rgba(0,0,0,.15)}.panel-title{display:flex;align-items:center;gap:.55rem;min-height:48px;padding:0 1rem;border-bottom:1px solid var(--qr-line)}.panel-title svg{color:var(--qr-orange)}.panel-title h2{margin:0;font-size:.78rem;font-weight:650}.panel-title>span,.panel-title>div:last-child{margin-left:auto}.panel-title>span{color:#777;font:.64rem var(--font-mono)}.console-pipeline{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;align-items:center}.console-pipeline article{min-height:190px;padding:1.5rem;border:1px solid var(--qr-line);background:#121214}.console-pipeline article:first-child{border-radius:7px 0 0 7px}.console-pipeline article:last-child{border-radius:0 7px 7px 0}.console-pipeline article>div{display:flex;justify-content:space-between;color:var(--qr-orange)}.console-pipeline article>div span{color:#555;font:.65rem var(--font-mono)}.console-pipeline h2{margin:3.5rem 0 .5rem;font-size:1rem}.console-pipeline p{margin:0;color:#777;font-size:.75rem;line-height:1.5}.pipeline-arrow{width:34px;color:#555}.console-grid{display:grid;gap:1rem}.console-grid.two{grid-template-columns:1.1fr .9fr}.quickstart pre{margin:0;padding:1.4rem;overflow:auto;color:#d5d5d9;font:.75rem/1.8 var(--font-mono)}.checklist>a{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:.8rem;min-height:70px;padding:0 1rem;border-bottom:1px solid var(--qr-line)}.checklist>a:last-child{border:0}.checklist>a>svg:first-child{color:var(--qr-orange)}.checklist b,.checklist small{display:block}.checklist b{font-size:.76rem}.checklist small{margin-top:.25rem;color:#707077;font-size:.65rem}
/* Submit */
.submit-layout{display:grid;grid-template-columns:minmax(0,1fr) 330px;gap:1rem;align-items:start}.submit-builder{display:flex;flex-direction:column;gap:1rem}.editor-wrap{display:grid;grid-template-columns:44px 1fr;height:280px;background:#09090a}.line-numbers{display:flex;flex-direction:column;padding:.9rem .7rem;border-right:1px solid var(--qr-line);color:#4f4f55;text-align:right;font:.72rem/1.65 var(--font-mono)}.editor-wrap textarea{width:100%;height:100%;resize:none;border:0;outline:0;padding:.9rem 1rem;background:transparent;color:#e1e1e4;font:.78rem/1.65 var(--font-mono)}.source-actions{display:flex;align-items:center;justify-content:space-between;padding:.6rem 1rem;border-top:1px solid var(--qr-line);color:#666;font:.65rem var(--font-mono)}.source-actions button{display:flex;align-items:center;gap:.4rem;border:0;background:none;color:#aaa;cursor:pointer}.console-segments{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;padding:3px;border:1px solid var(--qr-line);border-radius:5px;background:#0d0d0f}.console-segments.compact{display:flex;padding:2px}.console-segments button{min-height:32px;border:0;border-radius:3px;background:transparent;color:#777;font-size:.68rem;text-transform:capitalize;cursor:pointer}.console-segments button.active{background:#252528;color:#fff}.routing-panel>.console-segments{margin:1rem}.form-grid{display:grid;gap:1rem;padding:0 1rem 1rem}.form-grid.three{grid-template-columns:repeat(3,1fr)}.form-grid.two{grid-template-columns:1fr 1fr}.form-grid label,.settings-section label,.modal-field,.onboarding-fields label{display:flex;flex-direction:column;gap:.45rem;color:#85858b;font-size:.68rem}.form-grid input,.form-grid select,.settings-section input,.settings-section select,.modal-field input,.modal-field select,.onboarding-fields input{width:100%;height:38px;border:1px solid var(--qr-line);border-radius:5px;background:#0d0d0f;color:#eee;padding:0 .7rem;outline:0}.form-grid input:focus,.form-grid select:focus,.modal-field input:focus,.onboarding-fields input:focus{border-color:rgba(255,107,0,.6)}.input-prefix{position:relative}.input-prefix i{position:absolute;left:.7rem;top:10px;font-style:normal;color:#666}.input-prefix input{padding-left:1.5rem}.backend-option{display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:.8rem;width:100%;min-height:66px;padding:.7rem 1rem;border:0;border-bottom:1px solid var(--qr-line);background:transparent;color:#ddd;text-align:left;cursor:pointer}.backend-option:hover{background:rgba(255,255,255,.025)}.backend-option.selected{background:rgba(255,107,0,.055);box-shadow:inset 2px 0 var(--qr-orange)}.backend-option:disabled{opacity:.42;cursor:not-allowed}.auto-mark{display:grid;place-items:center;width:34px;height:34px;border:1px solid rgba(56,189,248,.3);border-radius:5px;background:rgba(56,189,248,.06);color:var(--qr-blue)}.auto-mark.qpu{border-color:rgba(255,107,0,.3);background:rgba(255,107,0,.06);color:var(--qr-orange)}.backend-option b,.backend-option small{display:block}.backend-option b{font-size:.75rem}.backend-option small{margin-top:.25rem;color:#6f6f75;font-size:.63rem}.backend-badges{text-align:right}.backend-badges em{display:block;color:#999;font:normal .58rem var(--font-mono);text-transform:uppercase}.submit-review{position:sticky;top:64px;display:flex;flex-direction:column;gap:1rem}.review-panel,.result-panel{padding:1.2rem}.review-panel h2{margin:0 0 1rem;font-size:1.25rem}.review-panel dl,.result-panel dl{margin:0 0 1rem}.review-panel dl>div,.result-panel dl>div{display:flex;justify-content:space-between;padding:.6rem 0;border-bottom:1px solid var(--qr-line);font-size:.68rem}.review-panel dt,.result-panel dt{color:#707077}.review-panel dd,.result-panel dd{margin:0}.review-note{display:block;margin-top:.75rem;color:#626268;font-size:.6rem;line-height:1.5}.console-alert{display:flex;align-items:flex-start;gap:.5rem;margin:.8rem 0;padding:.7rem;border-radius:5px;font-size:.66rem}.console-alert.error{border:1px solid rgba(251,113,133,.2);background:rgba(251,113,133,.06);color:#fda4af}.spin{animation:spin 1s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.result-status{display:flex;align-items:center;gap:.7rem;margin-bottom:.8rem}.result-status>span{display:grid;place-items:center;width:30px;height:30px;border-radius:50%;background:rgba(74,222,128,.1);color:var(--qr-green)}.result-status small,.result-status b{display:block}.result-status small{color:var(--qr-green);font-size:.6rem;text-transform:uppercase}.result-status b{font:.75rem var(--font-mono)}.orange{color:var(--qr-orange-hover)}.counts>span{color:#666;font:.6rem var(--font-mono);text-transform:uppercase}.counts>div{display:grid;grid-template-columns:45px 1fr 35px;align-items:center;gap:.5rem;margin-top:.6rem;font-size:.65rem}.counts i{height:5px;background:var(--qr-orange);border-radius:2px}.counts b{text-align:right}
/* Tasks and keys */
.tasks-toolbar,.keys-toolbar{display:flex;align-items:center;justify-content:space-between;min-height:60px;padding:0 1rem;border-bottom:1px solid var(--qr-line)}.tasks-toolbar{color:#777;font-size:.7rem}.tasks-toolbar button{display:flex;gap:.4rem;border:0;background:none;color:#aaa;cursor:pointer}.tasks-head,.task-row{display:grid;grid-template-columns:1.4fr 1.2fr .8fr .7fr .8fr 20px;align-items:center;gap:1rem;padding:0 1rem}.tasks-head,.key-head{min-height:38px;border-bottom:1px solid var(--qr-line);color:#5f5f65;font:600 .58rem var(--font-mono);text-transform:uppercase}.task-row{width:100%;min-height:66px;border:0;border-bottom:1px solid var(--qr-line);background:transparent;color:#ccc;text-align:left;cursor:pointer}.task-row:hover{background:rgba(255,255,255,.02)}.task-row b,.task-row small{display:block}.task-row b{font-size:.7rem}.task-row small{margin-top:.2rem;color:#666;font-size:.6rem}.task-row>span:nth-child(n+3){font-size:.66rem}.task-row>span:nth-child(5){display:flex;align-items:center;gap:.45rem;text-transform:capitalize}.status-dot{width:6px;height:6px;border-radius:50%;background:#facc15}.status-dot.completed{background:var(--qr-green)}.status-dot.failed,.status-dot.cancelled{background:#fb7185}.rotate{transform:rotate(180deg)}.task-detail{display:grid;grid-template-columns:1fr 1fr;gap:2rem;padding:1.2rem 2rem;border-bottom:1px solid var(--qr-line);background:#0d0d0f}.task-detail>div>span{color:#666;font:.6rem var(--font-mono);text-transform:uppercase}.task-detail dl{display:flex;gap:2rem}.task-detail dt{color:#666;font-size:.6rem}.task-detail dd{margin:.25rem 0;font-size:.7rem}.mini-counts{margin-top:.8rem}.mini-counts>div{display:flex;justify-content:space-between;padding:.35rem 0;border-bottom:1px solid var(--qr-line);font-size:.68rem}.mini-counts button{display:flex;align-items:center;gap:.4rem;margin-top:.8rem;border:0;background:none;color:#ff9147;font-size:.65rem;cursor:pointer}.muted{color:#6f6f75;font-size:.7rem}.console-empty{display:grid;place-items:center;min-height:240px;color:#666}.console-empty p{margin:.5rem}.console-empty a{color:#ff9147;font-size:.7rem}.keys-toolbar>div{display:flex;align-items:center;gap:.7rem}.keys-toolbar>div svg{color:var(--qr-orange)}.keys-toolbar b,.keys-toolbar small{display:block}.keys-toolbar b{font-size:.76rem}.keys-toolbar small{margin-top:.2rem;color:#666;font-size:.62rem}.key-head,.key-row{display:grid;grid-template-columns:1.2fr 1.4fr .7fr .8fr 36px;align-items:center;gap:1rem;padding:0 1rem}.key-row{min-height:65px;border-bottom:1px solid var(--qr-line);font-size:.68rem}.key-row b,.key-row small{display:block}.key-row small{margin-top:.2rem;color:#666;font-size:.6rem}.key-row code,.created-key code{font-size:.66rem;color:#aaa}.env{width:max-content;padding:.25rem .4rem;border-radius:3px;background:rgba(74,222,128,.08);color:var(--qr-green);font:.58rem var(--font-mono);text-transform:uppercase}.env.test{background:rgba(56,189,248,.08);color:var(--qr-blue)}.console-note{padding:1rem;border:1px solid rgba(250,204,21,.12);border-radius:5px;background:rgba(250,204,21,.035);color:#777;font-size:.67rem}.console-note b{color:#d4d4d8}.modal-field{margin:1rem 0}.created-key{display:flex;align-items:center;gap:.5rem;margin:1rem 0;padding:.7rem;border:1px solid rgba(255,107,0,.25);border-radius:5px;background:#09090a}.created-key code{min-width:0;overflow:hidden;text-overflow:ellipsis}.created-key button{margin-left:auto;border:0;background:none;color:#ff9147;cursor:pointer}
/* Billing, settings, onboarding */
.billing-grid{grid-template-columns:.8fr 1.1fr 1.1fr}.balance-panel,.add-credit,.billing-connection{padding:1.2rem}.balance-panel strong{display:block;font:600 2.6rem var(--font-mono)}.balance-panel>span{color:#777;font-size:.68rem}.balance-panel>div{display:flex;gap:.5rem;margin-top:2rem;color:#777;font-size:.62rem}.balance-panel svg{color:var(--qr-green)}.amount-options{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;margin:1rem 0}.amount-options button{height:38px;border:1px solid var(--qr-line);border-radius:4px;background:#0d0d0f;color:#aaa;cursor:pointer}.amount-options button.active{border-color:var(--qr-orange);background:rgba(255,107,0,.08);color:#fff}.form-error{color:#fb7185;font-size:.68rem}.form-message{color:var(--qr-green);font-size:.68rem}.connection-state{display:flex;align-items:center;gap:.7rem;margin:1rem 0 2rem}.connection-state>i{width:8px;height:8px;border-radius:50%;background:#666}.connection-state>i.connected{background:var(--qr-green);box-shadow:0 0 8px rgba(74,222,128,.5)}.connection-state b,.connection-state small{display:block;font-size:.7rem}.connection-state small{margin-top:.25rem;color:#666;font-size:.62rem}.settings-grid{grid-template-columns:1fr 1fr}.settings-section{padding-bottom:1rem}.settings-section>.form-grid,.settings-section>label,.settings-section>button{margin:1rem}.toggle-row{flex-direction:row!important;align-items:center;justify-content:space-between}.toggle-row b,.toggle-row small{display:block}.toggle-row small{margin-top:.2rem;color:#666}.toggle-row input{width:36px!important;height:20px!important;accent-color:var(--qr-orange)}
.onboarding-page{min-height:100vh;display:flex;flex-direction:column;background-image:linear-gradient(rgba(255,255,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px);background-size:52px 52px}.onboarding-page>header{height:68px;display:flex;align-items:center;justify-content:space-between;padding:0 2rem;border-bottom:1px solid var(--qr-line);background:rgba(11,11,12,.9)}.onboarding-page>header>span,.onboarding-page>footer{color:#666;font:.62rem var(--font-mono);text-transform:uppercase}.onboarding-page>footer{margin-top:auto;padding:1.5rem;text-align:center}.onboarding-card{width:min(520px,calc(100% - 2rem));margin:clamp(2rem,8vh,6rem) auto;padding:2rem;border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(18,18,20,.96);box-shadow:0 30px 100px rgba(0,0,0,.35)}.onboarding-card h1{margin:0;font-size:2.2rem;line-height:1.05}.onboarding-lede{color:#85858b;font-size:.8rem;line-height:1.6}.onboarding-progress{display:flex;align-items:center;margin-bottom:2rem}.onboarding-progress span{display:grid;place-items:center;width:24px;height:24px;border:1px solid var(--qr-line);border-radius:50%;color:#666;font:.6rem var(--font-mono)}.onboarding-progress span.done{border-color:var(--qr-green);color:var(--qr-green)}.onboarding-progress span.active{border-color:var(--qr-orange);background:var(--qr-orange);color:#090909}.onboarding-progress i{flex:1;height:1px;background:var(--qr-line)}.onboarding-fields{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}.onboarding-pay{margin-top:.5rem}.onboarding-skip{display:block;margin:1rem 0 0 auto;border:0;background:none;color:#777;font-size:.66rem;cursor:pointer}.stripe-form{margin-top:1.2rem}.stripe-form .console-primary{margin-top:1rem}
@media(max-width:900px){.qr-public-nav{grid-template-columns:1fr auto}.qr-public-nav nav{display:none}.qr-hero{min-height:900px}.qr-hero-image{object-position:62% center}.qr-network-strip{grid-template-columns:1fr;padding:0}.qr-network-strip>div{min-height:58px;padding:.6rem 1.25rem;border-left:0;border-top:1px solid var(--qr-line)}.qr-flow-line{grid-template-columns:1fr 1fr}.qr-flow-line article:nth-child(2){border-right:0}.qr-section-intro.split{align-items:start;flex-direction:column;gap:1rem}.qr-developer{grid-template-columns:1fr}.submit-layout{grid-template-columns:1fr}.submit-review{position:static;display:grid;grid-template-columns:1fr 1fr}.billing-grid{grid-template-columns:1fr 1fr}.balance-panel{grid-column:1/-1}.console-account>span:not(.console-balance){display:none}}
@media(max-width:680px){.console-topbar{grid-template-columns:1fr auto}.console-workspace{display:none}.console-tabs{justify-content:start;overflow-x:auto}.console-tabs a{min-width:max-content}.console-tabs a span{display:none}.console-page-heading{align-items:start;flex-direction:column}.console-pipeline{grid-template-columns:1fr}.pipeline-arrow{margin:6px auto;transform:rotate(90deg)}.console-pipeline article,.console-pipeline article:first-child,.console-pipeline article:last-child{border-radius:6px}.console-grid.two,.settings-grid,.billing-grid,.submit-review{grid-template-columns:1fr}.form-grid.three,.form-grid.two,.onboarding-fields{grid-template-columns:1fr}.tasks-head,.key-head{display:none}.task-row{grid-template-columns:1.5fr 1fr auto}.task-row>span:nth-child(3),.task-row>span:nth-child(4),.task-row>span:nth-child(5){display:none}.task-detail{grid-template-columns:1fr}.key-row{grid-template-columns:1fr 1fr auto}.key-row>span:nth-child(3),.key-row>span:nth-child(4){display:none}.qr-table-head{display:none}.qr-table-row{grid-template-columns:1.8fr .5fr .65fr}.qr-table-row>span:nth-child(2),.qr-table-row>span:nth-child(5),.qr-table-row>span:nth-child(6){display:none}.qr-flow-line{grid-template-columns:1fr}.qr-flow-line article{border-right:0}.qr-footer{align-items:flex-start;flex-direction:column}.qr-hero h1{font-size:4.6rem}}
